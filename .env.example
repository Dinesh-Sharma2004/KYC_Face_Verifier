# Application
ENVIRONMENT=production
FRONTEND_ORIGIN=https://dinesh-sharma2004.github.io
ALLOWED_ORIGINS=https://dinesh-sharma2004.github.io
KYC_JOB_TOKEN_SECRET=<set-in-backend-hosting-secrets>
KYC_ADMIN_API_TOKEN=<set-in-backend-hosting-secrets>
KYC_ADMIN_USERNAME=<set-in-backend-hosting-secrets>
KYC_ADMIN_PASSWORD=<set-in-backend-hosting-secrets>
JWT_ISSUER=kyc-platform

# Database
DATABASE_URL=<set-in-backend-hosting-secrets>

# Queues and cache
REDIS_URL=<set-in-backend-hosting-secrets>
EVENT_BUS_URL=<set-in-backend-hosting-secrets>

# Object storage
OBJECT_STORAGE_PROVIDER=r2
STORAGE_ENDPOINT_URL=<set-in-backend-hosting-secrets>
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=<set-in-backend-hosting-secrets>
STORAGE_SECRET_KEY=<set-in-backend-hosting-secrets>
DOCUMENT_BUCKET=kyc-documents
REPORT_BUCKET=kyc-reports

# Upload limits
MAX_UPLOAD_BYTES=10485760

# OCR and AI providers
UNIFIED_EXTRACTOR_API_KEY=<set-in-backend-hosting-secrets>
GCP_PROJECT_ID=<set-in-backend-hosting-secrets>
GCP_LOCATION=us-central1
MODEL_NAME=gemini-2.5-pro

# Face verification
BEST_FACE_MODEL_PATH=./5_face_verification/face_verification_pipeline/best_face_verification_model.pkl
